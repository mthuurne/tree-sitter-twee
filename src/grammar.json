{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "twee",
  "rules": {
    "story": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "passage"
      }
    },
    "passage": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "heading"
        },
        {
          "type": "SYMBOL",
          "name": "_body"
        }
      ]
    },
    "_body": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "json"
        },
        {
          "type": "SYMBOL",
          "name": "prose"
        }
      ]
    },
    "prose": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "REPEAT1",
            "content": {
              "type": "SYMBOL",
              "name": "_prose_part"
            }
          }
        ]
      }
    },
    "_prose_part": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "macro"
        },
        {
          "type": "SYMBOL",
          "name": "image_link"
        },
        {
          "type": "SYMBOL",
          "name": "link"
        },
        {
          "type": "SYMBOL",
          "name": "variable"
        },
        {
          "type": "SYMBOL",
          "name": "html_tag"
        },
        {
          "type": "SYMBOL",
          "name": "plain_text"
        }
      ]
    },
    "heading": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "::"
        },
        {
          "type": "SYMBOL",
          "name": "name"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "tags"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "inline_json"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "\n"
        }
      ]
    },
    "link": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "[["
        },
        {
          "type": "SYMBOL",
          "name": "label"
        },
        {
          "type": "SYMBOL",
          "name": "separator"
        },
        {
          "type": "SYMBOL",
          "name": "dest"
        },
        {
          "type": "STRING",
          "value": "]]"
        }
      ]
    },
    "image_link": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "[img["
        },
        {
          "type": "SYMBOL",
          "name": "dest"
        },
        {
          "type": "STRING",
          "value": "]]"
        }
      ]
    },
    "tags": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "tag"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "json": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "_json_part"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_json_part": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "[^{}]+"
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "{"
              },
              {
                "type": "SYMBOL",
                "name": "_json_part"
              },
              {
                "type": "STRING",
                "value": "}"
              }
            ]
          }
        ]
      }
    },
    "inline_json": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "_inline_json_part"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_inline_json_part": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "[^{}\\n]+"
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "{"
              },
              {
                "type": "SYMBOL",
                "name": "_json_part"
              },
              {
                "type": "STRING",
                "value": "}"
              }
            ]
          }
        ]
      }
    },
    "macro": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<<"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "/"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "macro_name"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "macro_body"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ">>"
        }
      ]
    },
    "macro_name": {
      "type": "PATTERN",
      "value": "[=\\-]?[a-zA-Z][a-zA-Z0-9_\\-]*|[=\\-]"
    },
    "macro_body": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "variable"
          },
          {
            "type": "SYMBOL",
            "name": "string"
          },
          {
            "type": "SYMBOL",
            "name": "keyword_op"
          },
          {
            "type": "SYMBOL",
            "name": "number"
          },
          {
            "type": "PATTERN",
            "value": "[^>\"'$_?\\s]+"
          },
          {
            "type": "PATTERN",
            "value": "\\s+"
          },
          {
            "type": "STRING",
            "value": ">"
          }
        ]
      }
    },
    "variable": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[$_?]"
          },
          {
            "type": "PATTERN",
            "value": "[A-Za-z_$][A-Za-z0-9_$]*"
          }
        ]
      }
    },
    "string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "\"[^\"\\\\]*(\\\\.[^\"\\\\]*)*\""
        },
        {
          "type": "PATTERN",
          "value": "'[^'\\\\]*(\\\\.[^'\\\\]*)*'"
        }
      ]
    },
    "keyword_op": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "to|is|and|or|not|eq|ne|lt|gt|lte|gte"
        }
      }
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "-?\\d+(\\.\\d+)?"
        }
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "\\/\\*([^*]|\\*[^/])*\\*\\/"
          },
          {
            "type": "PATTERN",
            "value": "\\/%([^%]|%[^/])*%\\/"
          },
          {
            "type": "PATTERN",
            "value": "<!--([^-]|-[^-]|--[^>])*-->"
          }
        ]
      }
    },
    "html_tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "tag_name"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "attributes"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "tag_name": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "<"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "/"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "[a-zA-Z][a-zA-Z0-9\\-]*"
          }
        ]
      }
    },
    "attributes": {
      "type": "PATTERN",
      "value": "[^>]+"
    },
    "plain_text": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^<$_?\\/\\[\\n]+|[<$_?\\/\\[\\n]"
        }
      }
    },
    "separator": {
      "type": "PATTERN",
      "value": "->|<-|\\|"
    },
    "label": {
      "type": "PATTERN",
      "value": "[^ \\-<|\\]]([^\\-<|\\]]|-[^>]|<[^-])*[^ \\-<|\\]>]|[^ \\-<|\\]>]"
    },
    "name": {
      "type": "PATTERN",
      "value": "[^{\\[\\n ][^{\\[\\n]*[^{\\[\\n ]|[^{\\[\\n ]"
    },
    "dest": {
      "type": "PATTERN",
      "value": "[^\\] ][^\\]]*[^\\] ]|[^\\] ]"
    },
    "tag": {
      "type": "PATTERN",
      "value": "[a-z0-9]+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}